{
  "name": "forense-android-electron",
  "version": "1.0.0",
  "description": "Sistema de Gestión Forense para Dispositivos Android - React + Vite + Electron",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc && vite build && electron-builder",
    "electron:build:deb": "tsc && vite build && electron-builder --linux deb"
  },
  "keywords": [
    "forense",
    "android",
    "electron",
    "cadena-custodia",
    "andriller",
    "aleapp"
  ],
  "author": "Laboratorio Forense",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7",
    "axios": "^1.6.2",
    "date-fns": "^3.0.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.forense.android",
    "productName": "Forense Android",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": ["deb"],
      "category": "Utility",
      "maintainer": "Laboratorio Forense <forense@ejemplo.gob.ve>"
    },
    "deb": {
      "depends": [
        "python3 (>= 3.11)",
        "andriller",
        "aleapp"
      ]
    }
  }
}
