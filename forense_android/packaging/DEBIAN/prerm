#!/bin/bash
# Script pre-desinstalación del paquete forense-android

set -e

echo "Preparando desinstalación de Sistema Forense Android..."

# Eliminar enlace simbólico
rm -f /usr/bin/forense-android

# Nota: No eliminamos los datos de usuario en /var/lib/forense-android
# para preservar los casos en caso de reinstalación

echo "✅ Paquete preparado para desinstalación."
