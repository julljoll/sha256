{
  "name": "forense-android-electron",
  "version": "1.0.0",
  "description": "Sistema de Gestión Forense para Dispositivos Android - React + Vite + Electron + PWA",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc && vite build && electron-builder",
    "electron:build:deb": "tsc && vite build && electron-builder --linux deb",
    "electron:build:all": "tsc && vite build && electron-builder --linux --windows --mac"
  },
  "keywords": [
    "forense",
    "android",
    "electron",
    "cadena-custodia",
    "andriller",
    "aleapp",
    "pwa"
  ],
  "author": "Laboratorio Forense",
  "license": "MIT",
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12",
    "axios": "^1.15.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.11.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "build": {
    "appId": "com.forense.android",
    "productName": "Forense Android",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      "public/**/*"
    ],
    "linux": {
      "target": ["deb"],
      "category": "Utility",
      "maintainer": "Laboratorio Forense <forense@ejemplo.gob.ve>",
      "icon": "public/icon.png",
      "desktop": {
        "Name": "Forense Android",
        "Comment": "Sistema de Gestión Forense para Dispositivos Android",
        "Categories": "Utility;System;"
      }
    },
    "deb": {
      "depends": [
        "python3 (>= 3.11)",
        "andriller",
        "aleapp"
      ],
      "priority": "optional",
      "section": "utils"
    },
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/icon.icns",
      "category": "public.app-category.utilities"
    }
  }
}
